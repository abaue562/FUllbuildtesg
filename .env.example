# =============================================================
# OSS Empire — single source of truth for every secret
# Run `just secrets` to fill this in interactively (recommended).
# Anything left blank will be auto-generated by the wizard.
# =============================================================

# ── Core ─────────────────────────────────────────────────────
SERVER_IP=localhost
N8N_HOST=localhost
TIMEZONE=America/New_York

# ── AI keys (the only ones you actually need to paste yourself)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=

# ── SMTP (for outbound email — SendGrid free tier works)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM=noreply@yourapp.com
SENDGRID_API_KEY=

# ── n8n
N8N_USER=admin
N8N_PASSWORD=
N8N_API_KEY=

# ── Supabase
SUPABASE_DB_PASS=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── AFFiNE
AFFINE_ADMIN_EMAIL=admin@localhost
AFFINE_ADMIN_PASSWORD=
AFFINE_DB_PASSWORD=

# ── Coolify
COOLIFY_DB_PASSWORD=
COOLIFY_REDIS_PASSWORD=

# ── Chatwoot
CHATWOOT_DB_PASS=
CHATWOOT_SECRET=

# ── SurfSense
SURFSENSE_DB_PASSWORD=
SURFSENSE_SECRET=

# ── Twenty CRM
TWENTY_DB_PASS=
TWENTY_ACCESS_SECRET=
TWENTY_LOGIN_SECRET=
TWENTY_REFRESH_SECRET=

# ── Metabase / Mautic / Postiz / NocoDB / Formbricks / GrowthBook / GlitchTip / Temporal / Unleash
METABASE_DB_PASS=
MAUTIC_DB_PASS=
MAUTIC_DB_ROOT_PASS=
POSTIZ_DB_PASS=
POSTIZ_JWT_SECRET=
NOCODB_JWT=
FORMBRICKS_SECRET=
FORMBRICKS_ENCRYPT=
GROWTHBOOK_JWT=
GROWTHBOOK_ENCRYPT=
GLITCHTIP_DB_PASS=
GLITCHTIP_SECRET=
TEMPORAL_DB_PASS=
UNLEASH_DB_PASS=
UNLEASH_CLIENT_TOKEN=
UNLEASH_FRONTEND_TOKEN=

# ── Comms
WAHA_USER=admin
WAHA_PASS=
SMS_GW_USER=admin
SMS_GW_PASS=
TEXTBEE_JWT_SECRET=
TEXTBEE_NEXTAUTH_SECRET=

# ── Storage
MINIO_USER=admin
MINIO_PASSWORD=
MEILISEARCH_KEY=

# ── Ollama (local model server, optional)
OLLAMA_URL=http://host.docker.internal:11434
